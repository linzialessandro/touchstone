# cp .env.example .env  — never commit .env

# --- Kaggle (dataset / competition packaging) ---
KAGGLE_USERNAME=
KAGGLE_KEY=
KAGGLE_API_TOKEN=

# --- Open-weight field (prefer scoring on Kaggle GPU) ---
CODE_REASON_PROVIDER=mock
# Examples: Qwen/Qwen2.5-1.5B-Instruct  |  microsoft/Phi-3.5-mini-instruct
CODE_REASON_MODEL=Qwen/Qwen2.5-1.5B-Instruct
CODE_REASON_DEVICE_MAP=auto
CODE_REASON_MAX_NEW_TOKENS=1024
CODE_REASON_TEMPERATURE=0.0

# Optional HF hub (gated open weights) — usually set as a Kaggle Notebook secret
# HF_TOKEN=
# HUGGING_FACE_HUB_TOKEN=

